--end screen

function update_end()
	if btnp(🅾️) or btnp(❎) then
		_init()
	end
end

function draw_end()
	cls()
	rectfill(0,0,128,128,0)
	print("score",30,20,7)
--	print(score,28,20,7)
	print("game over",42,64,7)
	print("press any key to reset",20,80,7)
end
