--draw game
function draw_game()
	cls()
--	map()
	map_draw()
	draw_fx()
	print(#buls)
	
	--enemies
	for enemy in all(enemlist) do
		drawspr(enemy)
	end
	

if player == "alive" then
	draw_reimu()
end
	
	--bullet
	for mybul in all(buls) do
		drawspr(mybul)
	end

	
	-- ui lateral
	rectfill(80,0,128,128,1)
	
	print("lives",82,60,7)
	for i=1,lives do
		spr(37,75 + i*7,68)
	end
	
	print("bombs",82,80,7)
		for i=1,bombs do
		spr(53,75 + i*7,88)
	end
	
	--title
	spr(64,85,10,5,4)
	
	
end
