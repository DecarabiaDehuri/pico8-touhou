--init
function _init()
	mode="start"
	cls()
	
	map_init()
	enemlist={}
	local fairy1blu = {x=54,y=5,spr=34,type=1}
	add(enemlist,fairy1blu)
	
	local fairy1red={x=30,y=5,spr=50,type=2}
	add(enemlist,fairy1red)
	
	player={}
	player.x=focusx
	player.y=focusy

	-- bullet

	bulx=200
	buly=130
	
	local mybul = {}
	mybul.x=bulx
	mybul.y=buly
	mybul.spr=7
	add(buls,mybul)
	--[[ map og
	mapgen=true
 generate_map()
	spr(1,px,py,2,2)
	
	--map
	grasses={128,129,144,145,160,161,176,177}
]]--

	--player true focus position
	focusx = px+4
	focusy = py+7
	
	-- player sprite
	pspr=1
	-- edges of the screen
	min_x = 0
	max_x = 80
	min_y = 0
	max_y = 128
	

	
	-- life
	lives=3
	-- bomb
	bombs=3
	
	-- orbs rotation
	orb_timer = 0
	orb_speed = 8  -- changes rotation speed
	orb_frame = 0
	
	-- map move
	map_timer = 0
	map_speed = 100
	
	--particles
	effects = {}

 --effects settings
 trail_width = 3.5
 trail_colors = {8,2}
 trail_amount = 1

 fire_width = 3
 fire_colors = {8,9,10,5}
 fire_amount = 3

 explode_size = 5
 explode_colors = {8,9,6,5}
 explode_amount = 5

 --sfx
-- trail_sfx = 0
-- explode_sfx = 1
-- fire_sfx = 2
end
-->8
--update game

function update_game()

	--[[
	-- test game over
	if btnp(🅾️) and btnp(❎) then
	--	mode="end"
		dead()
	end
	--]]
	
	--collision check
	
	for check in all(enemlist) do
	 if col(check,enemlist) then
	 	dead()
	 end
	end

	--frames invul or dead
	dframes+=1
	iframes+=1
	
	if player=="dead" and dframes==60 then
		spawn_player()
	end
	
	--ui
	--max lives
	if lives > 6 then
		lives = 6
	end
	--max bombs
	if bombs > 6 then
		bombs = 6
	end
	
	scroll_counter += 1
	if scroll_counter >= 2 then
	    scroll_counter = 0
	    map_update()
	end
	--[[  map move og
	map_timer+=1
	if map_timer >= map_speed then
		map_timer = 0
		shift_map()
	end
	]]--
	
	--bullet move
	for i=#buls,1,-1 do
		local mybul=buls[i]
 	mybul.y=mybul.y-4
		--delete offscreen
		if mybul.y<-8 then
		 del(buls,mybul)
		end
	end

	--move enemies

	for enemy in all(enemlist) do
		enemy.spr+=0.05
		if enemy.type==1 then
			if enemy.spr>36 then
				enemy.spr=34
			end
		elseif enemy.type==2 then
			if enemy.spr>52 then
				enemy.spr=50
			end			
		end	
	end

	
	-- controls
	if player == "alive" then
		--shoot
		if btnp(4) then
			shoot()	
		end
		--focus
		if btn(❎) then
			pspd=1
			focus=true
		else
			focus=false
			pspd=2
		end
		--movement
		pspr=1
		if btn(⬅️) then
		 px-=pspd
		 pspr=8
		end
		if	btn(➡️) then
		 px+=pspd
		 pspr=10
		end
		if	btn(⬆️) then py-=pspd end
		if	btn(⬇️) then py+=pspd end
	end

	--orb rotate
	orb_timer += 1
	if orb_timer >= orb_speed then
		orb_timer = 0
		orb_frame = (orb_frame + 1) % 4
		if orb_frame == 0 then
    orb_x = false
    orb_y = true
		elseif orb_frame == 1 then
		  orb_x = true
		  orb_y = true
		elseif orb_frame == 2 then
		  orb_x = true
		  orb_y = false
		elseif orb_frame == 3 then
		  orb_x = false
		  orb_y = false
		end
	end
	
	--check edges
	focusx = px+4
	focusy = py+7
	if focusx < min_x then
	 px = max_x-12
	 sfx(2)
	elseif focusx+8 > max_x then
	 px = min_x-4
	 sfx(2)
	end
	if focusy+3 > max_y-1 then
	--	py = max_y-11
		py-=pspd
	elseif focusy-4 < min_y then
		py+=pspd
	--	py = min_y-2
	end
	
	buly=buly-2
		
	update_fx()

-- orbs trail
	if player == "alive" then
		if focus == false then
			trail(px+19,py+10,trail_width,trail_colors,trail_amount)
			trail(px-2,py+10,trail_width,trail_colors,trail_amount)
		else
		trail(px+17,py-1,trail_width,trail_colors,trail_amount)
		trail(px-1,py-1,trail_width,trail_colors,trail_amount)
		end
	end

end
