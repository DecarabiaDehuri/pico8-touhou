function update_start()
	if btnp(🅾️) then
		player="alive"
		mode="game"
	end
end

function draw_start()
	cls(4)
	spr(64,20,20,5,4)
	print("press 🅾️ to start",30,90)
	spr(74,70,30,6,7)
end
