--functions

function col(a,b)
	local a_left=a.x
	local a_top=a.y
	local a_right=a.x+7
	local a_bottom=a.y+7
	
	local b_left=b.x
	local b_top=b.y
	local b_right=b.x+7
	local b_bottom=b.y+7
	
	if a_top > b_bottom then return false end
	if b_top > a_bottom then return false end
	if a_left > b_right then return false end
	if b_left > a_right then return false end
		
	return true
end

function drawspr(myspr)
	spr(myspr.spr,myspr.x,myspr.y)
end

function spawn_enem(x,y,spr,type)
	local new_enem = {
	x = x,
	y = y,
	spr = spr,
	type = type
	}
	add(enemlist,new_enem)
end

function dead()
	player = "dead"
	lives-=1
	bombs=3
	sfx(3)
	explode(px+8,py+8,4,explode_colors,5)
	dframes=0
	if lives == 0 then
		mode="end"
	end
end

function spawn_player()
		px=31
		py=120
		player="alive"
		draw_reimu()
end

function draw_reimu()
	-- reimu
	spr(pspr,px,py,2,2)
	
	-- ying yang
	if focus == false then
		spr(39,px+15,py+5,1,1,orb_x,orb_y)
		spr(39,px-7,py+5,1,1,orb_x,orb_y)
	else
		spr(39,px+12,py-5,1,1,orb_x,orb_y)
		spr(39,px-4,py-5,1,1,orb_x,orb_y)
	end	
	
	--focus
	if focus==true then
		spr(6,px+4,py+3)
		circfill(px+7,py+7,2,7)
		circfill(px+8,py+7,2,7)
		circfill(px+8,py+6,2,7)
		circfill(px+7,py+6,2,7)
	end
end

function game_over()
	mode="end"
end

function shoot()
	--focus
	focusx = px+4
	focusy = py+7
	--where bullets spawn
	if focus ==true then
		bfireposl={x=px-4,y=py-10}
		bfireposr={x=px+12,y=py-10}
	else
		bfireposl={x=px-7,y=py}
		bfireposr={x=px+15,y=py}	
	end
	local newbull={}
		newbull.x=bfireposl.x
		newbull.y=bfireposl.y
		newbull.spr=7
	local newbulr={}
		newbulr.x=bfireposr.x
		newbulr.y=bfireposr.y
		newbulr.spr=7
	add(buls,newbull)
	add(buls,newbulr)
	sfx(1)
end

function map_init()
    bg_sprites = {128,129,144,145,160,161,176,177}
    road_left = {133,149,165,181}
    road_right = {134,150,166,182}
    rows = 32               -- enough buffer
    cols = 10
    bg = {}
    for x = 0, cols-1 do
        bg[x] = {}
        for r = 0, rows-1 do
        	if x == 4 then
   							 bg[x][r] = road_left[ flr(rnd(#road_left)) + 1 ]
									elseif x == 5 then
									  bg[x][r] = road_right[ flr(rnd(#road_right)) + 1 ]
									else
									  bg[x][r] = bg_sprites[ flr(rnd(#bg_sprites)) + 1 ]
									end
        end
    end
    top_idx = 0            -- which buffer row is at screen y=0
    scroll_y = 0
    scroll_speed = 1
    scroll_counter = 0
end

function map_update()
    scroll_y += scroll_speed
    if scroll_y >= 8 then
        scroll_y -= 8

        -- row that will become the top row after two shifts (currently offscreen)
        local future_top = (top_idx - 2 + rows) % rows
        for x = 0, cols-1 do
	        if x == 4 then
	   					 bg[x][future_top] = road_left[ flr(rnd(#road_left)) + 1 ]
									elseif x == 5 then
	    					bg[x][future_top] = road_right[ flr(rnd(#road_right)) + 1 ]
									else
          bg[x][future_top] = bg_sprites[flr(rnd(#bg_sprites)) + 1]
         end
        end

        -- shift the world down by one row
        top_idx = (top_idx - 1 + rows) % rows
    end
end

function map_draw()
    for x = 0, cols-1 do
        for screen_row = -1, 16 do
            local buffer_row = (top_idx + screen_row) % rows
            local y_pos = screen_row * 8 + scroll_y
            spr(bg[x][buffer_row], x * 8, y_pos)
        end
    end
end
